# QuickBooks Online app credentials from developer.intuit.com
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8000/callback
QBO_ENVIRONMENT=sandbox
QBO_TOKEN_FILE=secrets/qbo_token.json

# Download this Desktop OAuth credential from Google Cloud.
GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_TOKEN_FILE=secrets/google_token.json

# Keyrenter AppFolio owner-portal login (fetch-keyrenter auto-login on session expiry).
APPFOLIO_EMAIL=
APPFOLIO_PASSWORD=

# Optional. Leave blank to use the API's base behavior.
QBO_MINOR_VERSION=
